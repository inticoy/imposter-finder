# dev=로컬 테스트용 채널, prod=실제 서비스 채널
BOT_ENV=dev

# Discord Developer Portal에서 발급한 봇 토큰
DISCORD_BOT_TOKEN=your-bot-token-here

# Discord 포럼 채널 ID (채널 우클릭 → ID 복사)
DISCORD_CHANNEL_DEV=your-dev-channel-id
DISCORD_CHANNEL_PROD=your-prod-channel-id

# 선택: 고정 thread에 계속 댓글로 전송하려면 thread ID를 넣습니다.
# 비워두면 DISCORD_CHANNEL_*에 매치별 thread/message를 생성합니다.
DISCORD_THREAD_DEV=your-dev-thread-id
DISCORD_THREAD_PROD=your-prod-thread-id

PUBG_API_KEY=발급받은키
PUBG_PLATFORM=steam
